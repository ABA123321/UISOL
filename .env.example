## Rune Abyss (UISOL) env example
## Copy to `.env.local` and fill your deployed addresses.

# Chain config
NEXT_PUBLIC_CHAIN_ID=56
NEXT_PUBLIC_RPC_URL=https://bsc-dataseed.binance.org

# Optional: first block number after deployment (speeds up log scans)
NEXT_PUBLIC_DEPLOY_BLOCK=0

# Token addresses
# BSC Mainnet USDT (BEP20): 0x55d398326f99059fF775485246999027B3197955
NEXT_PUBLIC_USDT_ADDRESS=0x55d398326f99059fF775485246999027B3197955

# Game contracts (fill after deployment)
NEXT_PUBLIC_ADVENT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_MATERIALS_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_CHARACTER_NFT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_REFERRAL_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_STAMINA_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_MARKETPLACE_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_GAME_ADDRESS=0x0000000000000000000000000000000000000000

