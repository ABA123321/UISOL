## Rune Abyss (UISOL) env example
## 默认值已硬编码在 lib/web3/addresses.ts，仓库克隆即跑（连接 BSC 主网读真实数据）。
## 如需切到测试网或自定义部署，把以下变量填进 `.env.local` 覆盖即可。

# Chain config
NEXT_PUBLIC_CHAIN_ID=56
NEXT_PUBLIC_RPC_URL=https://bsc-dataseed.binance.org

# Optional: 部署起始区块（用于加速事件扫描；最早 referralRegistry 区块）
NEXT_PUBLIC_DEPLOY_BLOCK=95047672

# Tokens
# BSC Mainnet USDT (BEP20)
NEXT_PUBLIC_USDT_ADDRESS=0x55d398326f99059fF775485246999027B3197955

# Rune Abyss · BSC Mainnet 部署
NEXT_PUBLIC_REFERRAL_REGISTRY_ADDRESS=0xdEBE3c804f66d8B2Ab24e06beD3E186Fd9808d77
NEXT_PUBLIC_STAMINA_ADDRESS=0x6CED5955EA4F61C489027EA511DB3FFEFE697F03
NEXT_PUBLIC_ADVENT_ADDRESS=0x5106E2921eBeeDe892eB4E3dAb660685b9bB3Fcb
NEXT_PUBLIC_MATERIALS_ADDRESS=0x69028EeBbE70B964cC977551D0a0E6BDbf01Ac49
NEXT_PUBLIC_CHARACTER_NFT_ADDRESS=0x31148e25A97C1E83E82a0c0029d4A2d7cD8b1c22
NEXT_PUBLIC_GAME_ADDRESS=0xe1708805b3321d04167b5fCb96D2BaB336824130
NEXT_PUBLIC_MARKETPLACE_ADDRESS=0x06975003578Da8Cc312903627e881bd5B0ad09fe
